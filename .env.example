# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — copia este archivo a `.env.local` y rellena los valores.
# `.env.local` está en .gitignore: NUNCA se commitea.
#
# En desarrollo local, `supabase start` imprime estos valores en la terminal.
# Cópialos desde ahí. Los valores de abajo son los DEFAULTS del stack local de
# Supabase CLI (son públicos y conocidos, sólo válidos en local).
# ─────────────────────────────────────────────────────────────────────────────

# URL pública de la API de Supabase — la usa el NAVEGADOR (corre en el host),
# por eso siempre apunta a 127.0.0.1 aunque la app esté dockerizada.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# URL interna que usa el SERVIDOR Next.js cuando corre DENTRO de un contenedor
# para alcanzar a Supabase (que corre en otro stack Docker, en el host).
# Si corres la app en el host (sin Docker), déjala vacía o igual a la pública.
SUPABASE_INTERNAL_URL=http://host.docker.internal:54321

# Clave anónima (segura para el navegador; RLS la protege).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Clave de servicio (BYPASSEA RLS). SÓLO en el servidor, NUNCA exponer al cliente.
# Úsala únicamente en route handlers / server actions de confianza.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# URL base de la app (para callbacks de auth, links en correos, etc.).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
